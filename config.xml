<?xml version='1.0' encoding='utf-8'?>
<widget id="com.spilx.analyst" version="1.0.1" xmlns="http://www.w3.org/ns/widgets" xmlns:android="http://schemas.android.com/apk/res/android">
    <name>SPIL-X PRO</name>
    <description>AI Field Analyst Mobile (Android 13 Optimized)</description>
    <author email="destek@spilx.com">SPIL-X Team</author>
    
    <content src="index.html" />
    
    <plugin name="cordova-plugin-bluetooth-serial" source="npm" />
    <plugin name="cordova-plugin-file" source="npm" />
    <plugin name="cordova-plugin-android-permissions" source="npm" />

    <platform name="android">
        <preference name="Scheme" value="file" />
        <preference name="Hostname" value="localhost" />
        
        <preference name="AndroidInsecureFileModeEnabled" value="true" />
        <preference name="AllowUntrustedCertificate" value="true" />

        <config-file target="AndroidManifest.xml" parent="/*">
            <uses-permission android:name="android.permission.BLUETOOTH_SCAN" android:usesPermissionFlags="neverForLocation" />
            <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
            <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />
            <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
            <uses-permission android:name="android.permission.READ_EXTERNAL_STORAGE" />
            <uses-permission android:name="android.permission.WRITE_EXTERNAL_STORAGE" />
        </config-file>
        
        <preference name="android-targetSdkVersion" value="33" />
        <preference name="Fullscreen" value="true" />
        <preference name="Orientation" value="portrait" />
    </platform>

    <access origin="*" />
    <allow-navigation href="*" />
    <allow-navigation href="file://*" />
    <allow-navigation href="content://*" />
    <allow-intent href="*" />
    
    <preference name="AllowInlineMediaPlayback" value="true" />
    <preference name="BackupWebStorage" value="none" />

</widget>
